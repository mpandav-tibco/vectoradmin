{
  "name": "vector-admin-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/tests/integration/**'",
    "test:watch": "vitest --exclude 'src/tests/integration/**'",
    "test:all": "vitest run",
    "test:integration": "vitest run --reporter=verbose src/tests/integration",
    "test:integration:weaviate": "vitest run --reporter=verbose src/tests/integration/weaviate.integration.test.ts",
    "test:integration:qdrant": "vitest run --reporter=verbose src/tests/integration/qdrant.integration.test.ts",
    "test:integration:chroma": "vitest run --reporter=verbose src/tests/integration/chroma.integration.test.ts",
    "seed": "node src/tests/seed.mjs",
    "seed:reset": "node src/tests/seed.mjs --reset"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.4.2",
    "@tanstack/react-query": "^5.40.0",
    "@tanstack/react-query-devtools": "^5.40.0",
    "@tanstack/react-table": "^8.17.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.394.0",
    "mammoth": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.51.5",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^4.1.5"
  }
}
